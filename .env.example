# QueuePilot configuration
# Copy to .env and fill in values — never commit .env

# Optional: override the default SQLite database path
# Default: ~/Library/Application Support/queuepilot/queuepilot.db (macOS)
# QUEUEPILOT_DATA_DIR=

# Optional: Telegram bot ingestion
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: Ollama local AI (disabled by default)
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: GitHub sync (Phase 5)
# GITHUB_TOKEN=
# GITHUB_OWNER=
# GITHUB_REPO=
